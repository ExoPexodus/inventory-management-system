# Copy to .env and adjust. Used by docker-compose and local API.

POSTGRES_USER=ims
POSTGRES_PASSWORD=ims_dev_change_me
POSTGRES_DB=ims

DATABASE_URL=postgresql+psycopg2://ims:ims_dev_change_me@localhost:5432/ims

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

API_HOST=0.0.0.0
API_PORT=8000

# Host port published for the `api` service in docker compose (container still uses 8000 internally).
API_PUBLISH_PORT=8001

# Protects POST /v1/admin/* and GET /v1/admin/*. Set the same in admin-web server secrets for dashboards.
ADMIN_API_TOKEN=change-me-admin-token

# URL embedded in staff enrollment QR codes — must be reachable from staff phones, not the host machine.
# Local dev (LAN):  http://192.168.x.x:8001   (use your machine's LAN IP, not localhost)
# Production:       https://api.yourdomain.com  (HTTPS, port omitted when using standard 443)
# Custom SSL port:  https://api.yourdomain.com:8443
PUBLIC_API_URL=http://192.168.18.2:8001
