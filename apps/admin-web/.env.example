# Server-side only (not NEXT_PUBLIC). Copy to .env.local for `next dev`.
# URL the Next.js server uses to reach the central API (Docker: http://api:8000).
API_INTERNAL_URL=http://localhost:8001

# HttpOnly operator cookie: set true only when the admin UI is served over HTTPS (or proxy sets X-Forwarded-Proto: https). For http://localhost use false.
# COOKIE_SECURE=false

# Fallback if API_INTERNAL_URL is unset
API_URL=http://localhost:8001

# Optional: legacy static admin token for direct server fetches (avoid in production; prefer operator login).
# ADMIN_API_TOKEN=
