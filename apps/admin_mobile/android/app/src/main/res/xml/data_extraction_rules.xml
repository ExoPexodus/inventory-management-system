<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for API level 31+.
    For API 30 and below see backup_rules.xml.

    Using <include> means only the listed paths are backed up; everything else
    (including FlutterSecureStorage / EncryptedSharedPreferences) is implicitly
    excluded — no need for an explicit <exclude> rule.
-->
<data-extraction-rules disableIfNoEncryptionCapabilities="true">
    <cloud-backup>
        <include domain="sharedpref" path="FlutterSharedPreferences" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="FlutterSharedPreferences" />
    </device-transfer>
</data-extraction-rules>
